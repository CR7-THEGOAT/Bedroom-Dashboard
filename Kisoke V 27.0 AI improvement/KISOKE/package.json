{
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:http": "vite --host 0.0.0.0 --port 5173",
    "dev:https": "vite --host 0.0.0.0 --port 5174",
    "electron": "electron electron/main.cjs",
    "dev:desktop": "concurrently -k \"npm run dev:http\" \"wait-on http://127.0.0.1:5173 && npm run electron\"",
    "build": "vite build",
    "build:desktop": "npm run build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "suncalc": "^1.9.0",
    "three": "^0.184.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "electron": "^42.4.1",
    "playwright": "^1.60.0",
    "vite": "^8.0.16",
    "wait-on": "^8.0.2"
  }
}
