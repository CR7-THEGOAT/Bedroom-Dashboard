#!/usr/bin/env bash
set -euo pipefail

echo "Bedroom Dashboard full software installer for Ubuntu"
echo "This installs the packages needed for display, sound, Night Light, Wi-Fi, Bluetooth, power mode, battery status, Tailscale, Ollama, frontend, and backend."

if ! command -v sudo >/dev/null 2>&1; then
  echo "sudo is required. Run this on Ubuntu with a normal admin user."
  exit 1
fi

sudo apt update
sudo apt install -y \
  curl \
  ca-certificates \
  gnupg \
  python3 \
  python3-venv \
  python3-pip \
  nodejs \
  npm \
  brightnessctl \
  network-manager \
  bluetooth \
  bluez \
  pulseaudio-utils \
  wireplumber \
  libglib2.0-bin \
  x11-xserver-utils \
  power-profiles-daemon \
  upower \
  rtl-sdr \
  dump1090-mutability

if ! command -v tailscale >/dev/null 2>&1; then
  curl -fsSL https://tailscale.com/install.sh | sh
fi

if ! command -v ollama >/dev/null 2>&1; then
  curl -fsSL https://ollama.com/install.sh | sh
fi

if [ -d "backend" ]; then
  python3 -m venv backend/.venv
  backend/.venv/bin/python -m pip install --upgrade pip
  backend/.venv/bin/pip install -r backend/requirements.txt
fi

if [ -f "package.json" ]; then
  npm install
fi

sudo usermod -aG video "$USER" || true

export OLLAMA_MODELS="$(pwd)/ollama"
mkdir -p "$OLLAMA_MODELS"
ollama pull llama3.2 || true
ollama pull gemma2:2b || true
ollama pull phi3.5 || true
ollama pull qwen2.5:3b || true

cat <<'DONE'

Ubuntu install finished.

Run Bedroom Dashboard with:
  ALLOW_DEVICE_CONTROL=true bash start-kiosk.sh

Optional Tailscale:
  sudo tailscale up
  sudo tailscale serve --bg 5173

Windows testing install commands:
  winget install OpenJS.NodeJS.LTS Python.Python.3.12 Tailscale.Tailscale Ollama.Ollama
  powershell -ExecutionPolicy Bypass -File .\run_local_windows.ps1

Important:
  Log out and back in after this install so brightness permissions from the video group apply.
DONE
